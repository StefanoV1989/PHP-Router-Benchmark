{
    "name": "router-benchmarks/php-router-benchmarks",
    "description": "Neutral, reproducible benchmarks for standalone PHP routers",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.4.1 <8.5",
        "altorouter/altorouter": "2.0.3",
        "bramus/router": "1.6.1",
        "illuminate/routing": "13.21.1",
        "nikic/fast-route": "1.3.0",
        "pecee/simple-router": "5.4.1.7",
        "stefanov1989/ariel-radix-router": "1.0.2",
        "symfony/routing": "8.1.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.87",
        "phpbench/phpbench": "^1.4",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.3"
    },
    "autoload": {
        "psr-4": {
            "RouterBenchmarks\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RouterBenchmarks\\Benchmarks\\": "benchmarks/",
            "RouterBenchmarks\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "@php -d error_reporting='E_ALL & ~E_DEPRECATED & ~E_USER_DEPRECATED' vendor/bin/phpunit",
        "analyse": "@php vendor/bin/phpstan analyse --memory-limit=1G",
        "format": "@php vendor/bin/php-cs-fixer fix",
        "format:check": "@php vendor/bin/php-cs-fixer fix --dry-run --diff",
        "benchmark": "@php bin/benchmark quick",
        "benchmark:quick": "@php bin/benchmark quick",
        "benchmark:full": "@php bin/benchmark full",
        "benchmark:memory": "@php bin/benchmark memory",
        "benchmark:cache": "@php bin/benchmark cache",
        "benchmark:export": "@php bin/export-results",
        "verify": "@php bin/verify"
    },
    "config": {
        "process-timeout": 0,
        "allow-plugins": {
            "phpbench/phpbench": true
        },
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "prefer-stable": true,
    "minimum-stability": "stable"
}
