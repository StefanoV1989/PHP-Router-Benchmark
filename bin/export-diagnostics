#!/usr/bin/env php
<?php

declare(strict_types=1);

error_reporting(E_ALL & ~E_DEPRECATED & ~E_USER_DEPRECATED);

$input = $argv[1] ?? null;
if (!\is_string($input) || !is_file($input)) {
    fwrite(STDERR, "Usage: export-diagnostics <memory-or-cache.json>\n");
    exit(2);
}

$document = json_decode((string) file_get_contents($input), true, flags: JSON_THROW_ON_ERROR);
if (!\is_array($document) || !\is_array($document['environment'] ?? null) || !\is_array($document['results'] ?? null)) {
    throw new RuntimeException('Invalid diagnostic result document.');
}
$environment = $document['environment'];
$rows = $document['results'];
$runtime = [
    'php_version' => (string) ($environment['php']['version'] ?? 'unknown'),
    'runtime_profile' => (string) ($environment['run']['runtime_profile'] ?? 'unknown'),
    'execution_environment' => (string) ($environment['execution_environment'] ?? 'unknown'),
    'opcache_enable' => (string) ($environment['runtime_target']['opcache.enable'] ?? 'unknown'),
    'opcache_enable_cli' => (string) ($environment['runtime_target']['opcache.enable_cli'] ?? 'unknown'),
    'opcache_jit' => (string) ($environment['runtime_target']['opcache.jit'] ?? 'unknown'),
    'opcache_jit_buffer_size' => (string) ($environment['runtime_target']['opcache.jit_buffer_size'] ?? 'unknown'),
    'opcache_memory_consumption' => (string) ($environment['runtime_target']['opcache.memory_consumption'] ?? 'unknown'),
    'opcache_validate_timestamps' => (string) ($environment['runtime_target']['opcache.validate_timestamps'] ?? 'unknown'),
    'error_reporting' => (string) ($environment['runtime_target']['error_reporting'] ?? 'unknown'),
];
$rows = array_map(static fn (array $row): array => [...$runtime, ...$row], $rows);
$isMemory = str_contains($input, '.memory.json');
if (!$isMemory) {
    $metrics = ['generation_ns', 'load_ns', 'first_dispatch_ns', 'subsequent_dispatch_ns'];
    foreach ($metrics as $metric) {
        $fastest = [];
        foreach ($rows as $row) {
            $size = (string) ($row['size'] ?? 'unknown');
            $value = (float) ($row[$metric] ?? 0.0);
            if ($value > 0.0) {
                $fastest[$size] = isset($fastest[$size]) ? min($fastest[$size], $value) : $value;
            }
        }
        foreach ($rows as &$row) {
            $size = (string) ($row['size'] ?? 'unknown');
            $value = (float) ($row[$metric] ?? 0.0);
            $prefixName = preg_replace('/_ns$/', '', $metric) ?? $metric;
            $row[$prefixName . '_ops_per_second'] = $value > 0.0 ? 1_000_000_000 / $value : null;
            $isDispatch = \in_array($prefixName, ['first_dispatch', 'subsequent_dispatch'], true);
            $row[$prefixName . '_requests_per_second'] = $isDispatch
                ? $row[$prefixName . '_ops_per_second']
                : null;
            $row[$prefixName . '_requests_per_minute'] = $isDispatch
                && $row[$prefixName . '_requests_per_second'] !== null
                ? $row[$prefixName . '_requests_per_second'] * 60
                : null;
            $row[$prefixName . '_relative'] = $value > 0.0 && isset($fastest[$size])
                ? $value / $fastest[$size]
                : null;
        }
        unset($row);
    }
}

$document['results'] = $rows;
file_put_contents(
    $input,
    json_encode($document, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES | JSON_THROW_ON_ERROR) . PHP_EOL,
    LOCK_EX,
);

$prefix = preg_replace('/\.json$/', '', $input);
if (!\is_string($prefix)) {
    throw new RuntimeException('Unable to determine export prefix.');
}
$columns = [];
foreach ($rows as $row) {
    foreach (array_keys($row) as $column) {
        $columns[$column] = true;
    }
}
$columns = array_keys($columns);

$stream = fopen($prefix . '.csv', 'wb');
if ($stream === false) {
    throw new RuntimeException('Unable to create diagnostic CSV.');
}
try {
    fputcsv($stream, $columns);
    foreach ($rows as $row) {
        fputcsv($stream, array_map(static fn (string $column): mixed => $row[$column] ?? null, $columns));
    }
} finally {
    fclose($stream);
}

$kind = $isMemory ? 'Memory' : 'Cache lifecycle';
$green = static function (string $formatted, float $value, float $baseline, bool $higherIsBetter = false): string {
    $isBetter = $higherIsBetter ? $value > $baseline : $value < $baseline;

    return $isBetter ? '<span style="color: #16833b;">' . $formatted . '</span>' : $formatted;
};
$markdown = '# ' . $kind . " benchmark report\n\n";
$markdown .= \sprintf(
    'PHP `%s`; runtime `%s`; execution `%s`; OPcache `%s`; OPcache CLI `%s`; JIT `%s`; '
    . "JIT buffer `%s`; OPcache memory `%s`; validate timestamps `%s`; error_reporting `%s`.\n\n",
    ...array_values($runtime),
);
$markdown .= "Dataset seed: `19890717`. Containerized and native-host results must not be combined.\n\n";
$markdown .= 'Relative values are calculated only within the same timed metric and route count; 1.00x is fastest. '
    . 'Rows are ordered inside each route-count group. A green value on a later row is better than the first row '
    . "for that individual column.\n\n";
if ($isMemory) {
    usort($rows, static fn (array $left, array $right): int => [$left['size'], $left['peak_bytes'], $left['router']]
        <=> [$right['size'], $right['peak_bytes'], $right['router']]);
    $markdown .= "## Memory\n\n";
    $markdown .= "Rows are ranked by peak memory; this does not imply that the first row leads every memory column.\n\n";
    $markdown .= "| Router | Routes | Empty bytes | Registered bytes | Registration delta | Finalization status | Finalized bytes | Finalization delta | Peak bytes |\n";
    $markdown .= "|---|---:|---:|---:|---:|---|---:|---:|---:|\n";
    $baseline = null;
    $size = null;
    foreach ($rows as $row) {
        if ($row['size'] !== $size) {
            $size = $row['size'];
            $baseline = $row;
        }
        if ($baseline === null) {
            throw new LogicException('Missing memory baseline.');
        }
        $winner = $row['router'] === $baseline['router'];
        $markdown .= \sprintf(
            "| %s | %d | %s | %s | %s | %s | %s | %s | %s |\n",
            $winner ? '**' . $row['router'] . '**' : $row['router'],
            $row['size'],
            $winner
                ? (string) $row['empty_bytes']
                : $green((string) $row['empty_bytes'], (float) $row['empty_bytes'], (float) $baseline['empty_bytes']),
            $winner
                ? (string) $row['registered_bytes']
                : $green(
                    (string) $row['registered_bytes'],
                    (float) $row['registered_bytes'],
                    (float) $baseline['registered_bytes'],
                ),
            $winner
                ? (string) $row['registration_delta_bytes']
                : $green(
                    (string) $row['registration_delta_bytes'],
                    (float) $row['registration_delta_bytes'],
                    (float) $baseline['registration_delta_bytes'],
                ),
            $row['finalization_status'],
            ($row['finalized_bytes'] ?? null) === null
                ? 'n/a'
                : ($winner || ($baseline['finalized_bytes'] ?? null) === null
                    ? (string) $row['finalized_bytes']
                    : $green(
                        (string) $row['finalized_bytes'],
                        (float) $row['finalized_bytes'],
                        (float) $baseline['finalized_bytes'],
                    )),
            ($row['finalization_delta_bytes'] ?? null) === null
                ? 'n/a'
                : ($winner || ($baseline['finalization_delta_bytes'] ?? null) === null
                    ? (string) $row['finalization_delta_bytes']
                    : $green(
                        (string) $row['finalization_delta_bytes'],
                        (float) $row['finalization_delta_bytes'],
                        (float) $baseline['finalization_delta_bytes'],
                    )),
            $winner
                ? (string) $row['peak_bytes']
                : $green((string) $row['peak_bytes'], (float) $row['peak_bytes'], (float) $baseline['peak_bytes']),
        );
    }
} else {
    $cacheScenarios = [
        'generation' => ['Cache Generation', 'generation_ns'],
        'load' => ['Cache Load', 'load_ns'],
        'first_dispatch' => ['First Dispatch After Cache Load', 'first_dispatch_ns'],
        'subsequent_dispatch' => ['Subsequent Cached Dispatch', 'subsequent_dispatch_ns'],
    ];
    foreach ($cacheScenarios as $key => [$title, $metric]) {
        $scenarioRows = $rows;
        usort($scenarioRows, static fn (array $left, array $right): int => [$left['size'], $left[$metric], $left['router']]
            <=> [$right['size'], $right[$metric], $right['router']]);
        $markdown .= '## ' . $title . "\n\n";
        $markdown .= "| Router | Routes | Time ns/op | Ops/s | Requests/s | Requests/min | Relative | Cache format |\n";
        $markdown .= "|---|---:|---:|---:|---:|---:|---:|---|\n";
        foreach ($scenarioRows as $row) {
            $markdown .= \sprintf(
                "| %s | %d | %.1f | %.0f | %s | %s | %.2fx | %s |\n",
                (float) $row[$key . '_relative'] === 1.0 ? '**' . $row['router'] . '**' : $row['router'],
                $row['size'],
                $row[$metric],
                $row[$key . '_ops_per_second'],
                $row[$key . '_requests_per_second'] === null
                    ? 'n/a'
                    : \sprintf('%.0f', $row[$key . '_requests_per_second']),
                $row[$key . '_requests_per_minute'] === null
                    ? 'n/a'
                    : \sprintf('%.0f', $row[$key . '_requests_per_minute']),
                $row[$key . '_relative'],
                $row['cache_format'],
            );
        }
        $markdown .= "\n";
    }
    usort($rows, static fn (array $left, array $right): int => [$left['size'], $left['cache_file_bytes'], $left['router']]
        <=> [$right['size'], $right['cache_file_bytes'], $right['router']]);
    $markdown .= "## Cache File Size\n\n";
    $markdown .= "| Router | Routes | Bytes | Cache format | Generation boundary |\n";
    $markdown .= "|---|---:|---:|---|---|\n";
    $size = null;
    foreach ($rows as $row) {
        $winner = $row['size'] !== $size;
        $size = $row['size'];
        $markdown .= \sprintf(
            "| %s | %d | %d | %s | %s |\n",
            $winner ? '**' . $row['router'] . '**' : $row['router'],
            $row['size'],
            $row['cache_file_bytes'],
            $row['cache_format'],
            $row['generation_boundary'],
        );
    }
}
file_put_contents($prefix . '.md', $markdown, LOCK_EX);

fwrite(STDOUT, $kind . ' results (' . \count($rows) . " rows)\n");
foreach ($rows as $row) {
    fwrite(STDOUT, \sprintf(
        "%-22s routes=%-6s %s\n",
        (string) ($row['router'] ?? 'unknown'),
        (string) ($row['size'] ?? '-'),
        json_encode($row, JSON_UNESCAPED_SLASHES | JSON_THROW_ON_ERROR),
    ));
}
fwrite(STDOUT, "Exported {$prefix}.md and {$prefix}.csv; JSON source already contains environment metadata.\n");
